{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuronforge.local/schemas/experiment_memory/nlo-hardware-profile.v1.schema.json",
  "title": "NLOHardwareProfile.v1",
  "description": "Canonical record of the hardware/runtime environment a run executed on. Metrics that cannot be captured are listed in unsupported_metrics rather than guessed.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "nlo-hardware-profile-v1" },
    "hardware_profile_id": { "type": "string", "pattern": "^hw-[a-z0-9][a-z0-9-]*$" },
    "captured_at": { "$ref": "#/$defs/utcTimestamp" },
    "capture_tool": { "type": "string", "minLength": 1, "maxLength": 200 },
    "os": { "type": "string", "minLength": 1, "maxLength": 200 },
    "kernel": { "type": "string", "minLength": 1, "maxLength": 200 },
    "cpu_model": { "type": "string", "minLength": 1, "maxLength": 200 },
    "cpu_cores": { "type": "integer", "minimum": 1 },
    "mem_total_gb": { "type": "number", "exclusiveMinimum": 0 },
    "mem_available_gb": { "type": "number", "minimum": 0 },
    "gpu": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "vram_gb": { "type": "number", "exclusiveMinimum": 0 }
      },
      "required": ["name"]
    },
    "unsupported_metrics": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 100 },
      "maxItems": 50
    },
    "notes": { "type": "string", "maxLength": 2000 },
    "recorded_at": { "$ref": "#/$defs/utcTimestamp" },
    "converted_from": { "$ref": "#/$defs/convertedFrom" }
  },
  "required": [
    "schema_version", "hardware_profile_id", "captured_at", "capture_tool", "recorded_at"
  ],
  "$defs": {
    "utcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "convertedFrom": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 500 },
        "note": { "type": "string", "maxLength": 1000 }
      },
      "required": ["path"]
    }
  }
}
