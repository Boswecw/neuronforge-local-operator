{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuronforge.local/schemas/skill_optimization/skill-eval-run.v1.schema.json",
  "title": "SkillEvalRun.v1",
  "description": "Deterministic or real-model evaluation run summary for a governed skill.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "skill-eval-run-v1" },
    "eval_run_id": { "$ref": "#/$defs/evalRunId" },
    "skill_id": { "$ref": "#/$defs/skillId" },
    "skill_version": { "$ref": "#/$defs/skillVersion" },
    "lane_id": { "$ref": "#/$defs/id" },
    "case_pack_id": { "$ref": "#/$defs/id" },
    "runner_mode": { "enum": ["fixture", "real_model"] },
    "fixture_id": {
      "oneOf": [
        { "$ref": "#/$defs/id" },
        { "type": "null" }
      ]
    },
    "model_id": {
      "oneOf": [
        { "$ref": "#/$defs/id" },
        { "type": "null" }
      ]
    },
    "started_at": { "$ref": "#/$defs/utcTimestamp" },
    "finished_at": { "$ref": "#/$defs/utcTimestamp" },
    "case_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/caseResult" },
      "minItems": 1
    },
    "summary": { "$ref": "#/$defs/runSummary" },
    "blocking_failures": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "notes": { "type": "string", "maxLength": 2000 }
  },
  "required": [
    "schema_version",
    "eval_run_id",
    "skill_id",
    "skill_version",
    "lane_id",
    "case_pack_id",
    "runner_mode",
    "fixture_id",
    "model_id",
    "started_at",
    "finished_at",
    "case_results",
    "summary",
    "blocking_failures"
  ],
  "$defs": {
    "caseId": {
      "type": "string",
      "pattern": "^cp-[0-9]{3}$"
    },
    "caseResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "case_id": { "$ref": "#/$defs/caseId" },
        "split": { "enum": ["train", "validation", "regression", "blocked"] },
        "source_packet_hash": { "$ref": "#/$defs/sha256" },
        "output_hash": { "$ref": "#/$defs/sha256" },
        "structured_output_valid": { "type": "boolean" },
        "finding_correctness": { "$ref": "#/$defs/scoreStatus" },
        "restraint_correctness": { "$ref": "#/$defs/scoreStatus" },
        "evidence_span_status": { "$ref": "#/$defs/qualityStatus" },
        "confidence_calibration": { "$ref": "#/$defs/qualityStatus" },
        "false_positive_severity": {
          "enum": ["none", "low", "moderate", "high", "not_applicable"]
        },
        "regression_status": { "enum": ["pass", "fail", "not_applicable"] },
        "score": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total": { "type": "number", "minimum": 0, "maximum": 1 },
            "schema_validity": { "type": "number", "minimum": 0, "maximum": 1 },
            "finding": { "type": "number", "minimum": 0, "maximum": 1 },
            "restraint": { "type": "number", "minimum": 0, "maximum": 1 },
            "evidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "required": ["total", "schema_validity", "finding", "restraint", "evidence", "confidence"]
        },
        "notes": { "type": "string", "maxLength": 1000 }
      },
      "required": [
        "case_id",
        "split",
        "source_packet_hash",
        "output_hash",
        "structured_output_valid",
        "finding_correctness",
        "restraint_correctness",
        "evidence_span_status",
        "confidence_calibration",
        "false_positive_severity",
        "regression_status",
        "score"
      ]
    },
    "evalRunId": {
      "type": "string",
      "pattern": "^skill-eval-run-[a-z0-9][a-z0-9-]*$",
      "maxLength": 160
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "minLength": 1,
      "maxLength": 160
    },
    "qualityStatus": {
      "enum": ["pass", "fail", "warning", "not_scored"]
    },
    "runSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cases_total": { "type": "integer", "minimum": 0 },
        "schema_valid_count": { "type": "integer", "minimum": 0 },
        "blocking_failure_count": { "type": "integer", "minimum": 0 },
        "aggregate_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "high_risk_false_positive_count": { "type": "integer", "minimum": 0 },
        "regression_failure_count": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "cases_total",
        "schema_valid_count",
        "blocking_failure_count",
        "aggregate_score",
        "high_risk_false_positive_count",
        "regression_failure_count"
      ]
    },
    "scoreStatus": {
      "enum": ["pass", "fail", "partial", "not_scored"]
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "skillId": {
      "type": "string",
      "pattern": "^skill-[a-z0-9][a-z0-9-]*$",
      "maxLength": 160
    },
    "skillVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9][a-z0-9.-]*)?$",
      "maxLength": 80
    },
    "utcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  }
}
