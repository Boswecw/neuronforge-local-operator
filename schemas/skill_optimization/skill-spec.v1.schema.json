{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuronforge.local/schemas/skill_optimization/skill-spec.v1.schema.json",
  "title": "SkillSpec.v1",
  "description": "Stable identity, lifecycle, and compatibility metadata for a governed skill artifact.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "skill-spec-v1" },
    "skill_id": { "$ref": "#/$defs/skillId" },
    "skill_version": { "$ref": "#/$defs/skillVersion" },
    "lane_id": { "$ref": "#/$defs/id" },
    "owner": { "type": "string", "minLength": 1, "maxLength": 200 },
    "state": {
      "enum": [
        "draft",
        "candidate_baseline",
        "accepted_baseline",
        "promoted",
        "superseded",
        "retired"
      ]
    },
    "artifact_posture": { "const": "candidate_only" },
    "source_path": { "$ref": "#/$defs/repoPath" },
    "skill_document_hash": { "$ref": "#/$defs/sha256" },
    "compatible_contracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "minItems": 1,
      "uniqueItems": true
    },
    "compatible_consumers": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "minItems": 1,
      "uniqueItems": true
    },
    "model_compatibility": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "supersedes": {
      "oneOf": [
        { "$ref": "#/$defs/skillVersion" },
        { "type": "null" }
      ]
    },
    "created_at": { "$ref": "#/$defs/utcTimestamp" },
    "updated_at": { "$ref": "#/$defs/utcTimestamp" },
    "notes": { "type": "string", "maxLength": 2000 }
  },
  "required": [
    "schema_version",
    "skill_id",
    "skill_version",
    "lane_id",
    "owner",
    "state",
    "artifact_posture",
    "source_path",
    "skill_document_hash",
    "compatible_contracts",
    "compatible_consumers",
    "created_at",
    "updated_at"
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "minLength": 1,
      "maxLength": 160
    },
    "repoPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/-]+$",
      "minLength": 1,
      "maxLength": 500
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "skillId": {
      "type": "string",
      "pattern": "^skill-[a-z0-9][a-z0-9-]*$",
      "maxLength": 160
    },
    "skillVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9][a-z0-9.-]*)?$",
      "maxLength": 80
    },
    "utcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  }
}
