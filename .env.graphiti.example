# Graphiti pilot environment — copy to .env.graphiti (gitignored) and edit.
#
# Version matrix (pinned; no floating latest tags):
#   python:        3.11 (repo standard)
#   graph backend: neo4j:5.26.0-community (docker-compose.graphiti-pilot.yml)
#   graphiti:      NOT INSTALLED in this phase; pin graphiti-core at G-06+
#                  integration after G-01..G-05 acceptance (plan README gate)
#   embeddings / enrichment provider: none (enrichment disabled)

# Local-only credential for the pilot backend. Never reuse a real secret.
NLO_GRAPH_NEO4J_PASSWORD=change-me-locally

# Required security defaults (plan 05) — do not weaken without a data-policy review.
NLO_GRAPH_ENRICHMENT_ENABLED=false
NLO_GRAPH_EXTERNAL_CONTENT_ALLOWED=false
NLO_GRAPH_BIND_HOST=127.0.0.1

# Fail-closed advisory freshness policy (REVIEW.md locked decision):
# any canonical record newer than the projection refuses advisory queries.
NLO_GRAPH_MAX_PROJECTION_LAG_SECONDS=0
