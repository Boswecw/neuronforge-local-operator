#!/bin/bash
# Operator wrapper for the experiment-memory pilot CLI (plan 08 commands):
#
#   scripts/graph/nlo-graph current-baseline <contract>
#   scripts/graph/nlo-graph baseline-history <contract>
#   scripts/graph/nlo-graph recurring-failures <contract> [--include-fixtures]
#   scripts/graph/nlo-graph compare-runs <run-a> <run-b>
#   scripts/graph/nlo-graph explain-candidate <candidate-id>
#   scripts/graph/nlo-graph validate | rebuild [--prove] | status | verify-live
#
# Advisory only: output is never authoritative and never a promotion decision.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

# Repo convention (requirements.txt): deps live in .venv. Prefer it when the
# caller is not already inside a virtualenv, so PEP 668 hosts work untouched.
PYTHON3="python3"
if [[ -z "${VIRTUAL_ENV:-}" && -x "$REPO_ROOT/.venv/bin/python3" ]]; then
  PYTHON3="$REPO_ROOT/.venv/bin/python3"
fi

export PYTHONPATH="$REPO_ROOT/src:${PYTHONPATH:-}"
exec "$PYTHON3" -m nlo_experiment_memory.cli "$@"
